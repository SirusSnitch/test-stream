# Ignore images folder and output folder
/venv/
/__pycache__/

# Ignore ONNX models if you don't want to track them
*.onnx

# Ignore Visual Studio / BuildTools files
*.obj
*.exe
*.pdb
*.ilk
*.log
*.suo
*.user
*.ncb
*.opensdf
*.sdf
*.vcxproj.user
*.VC.db
*.VC.VC.opendb

# Ignore temporary files
*.tmp
*.temp
*.bak
*.swp

# Ignore C runtime output
*.out
*.h

# Ignore compiled Python / pip cache (if you also use Python)
__pycache__/
venv/
*.pyc
*.pyo